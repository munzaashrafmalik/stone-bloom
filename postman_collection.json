{
  "info": {
    "name": "Pakistani Store - Customer Service APIs",
    "description": "Complete API collection for Contact, FAQ, Pages, and Newsletter endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Contact Form",
      "item": [
        {
          "name": "Submit Contact Form",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"03001234567\",\n  \"subject\": \"Product Inquiry\",\n  \"message\": \"I would like to know more about your products.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/contact",
              "host": ["{{baseUrl}}"],
              "path": ["contact"]
            }
          }
        },
        {
          "name": "Get My Messages (Auth Required)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contact/my-messages",
              "host": ["{{baseUrl}}"],
              "path": ["contact", "my-messages"]
            }
          }
        },
        {
          "name": "Get All Contacts (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/contact/admin?status=new&page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["contact", "admin"],
              "query": [
                {"key": "status", "value": "new"},
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "Update Contact Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"adminNotes\": \"Issue resolved via email\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/contact/admin/:id",
              "host": ["{{baseUrl}}"],
              "path": ["contact", "admin", ":id"]
            }
          }
        }
      ]
    },
    {
      "name": "FAQs",
      "item": [
        {
          "name": "Get All FAQs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/faq",
              "host": ["{{baseUrl}}"],
              "path": ["faq"]
            }
          }
        },
        {
          "name": "Get FAQs by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/faq?category=shipping",
              "host": ["{{baseUrl}}"],
              "path": ["faq"],
              "query": [{"key": "category", "value": "shipping"}]
            }
          }
        },
        {
          "name": "Get Single FAQ",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/faq/:id",
              "host": ["{{baseUrl}}"],
              "path": ["faq", ":id"]
            }
          }
        },
        {
          "name": "Submit FAQ Feedback",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"helpful\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/faq/:id/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["faq", ":id", "feedback"]
            }
          }
        },
        {
          "name": "Create FAQ (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"question\": \"New Question?\",\n  \"answer\": \"Answer to the question\",\n  \"category\": \"general\",\n  \"order\": 1,\n  \"isPublished\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/faq/admin",
              "host": ["{{baseUrl}}"],
              "path": ["faq", "admin"]
            }
          }
        }
      ]
    },
    {
      "name": "Pages",
      "item": [
        {
          "name": "Get All Pages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages",
              "host": ["{{baseUrl}}"],
              "path": ["pages"]
            }
          }
        },
        {
          "name": "Get Page by Slug",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/pages/about-us",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "about-us"]
            }
          }
        },
        {
          "name": "Create Page (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Page\",\n  \"slug\": \"new-page\",\n  \"content\": \"# Page Content\\n\\nPage body here\",\n  \"metaDescription\": \"Page description\",\n  \"isPublished\": true,\n  \"order\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/pages/admin",
              "host": ["{{baseUrl}}"],
              "path": ["pages", "admin"]
            }
          }
        }
      ]
    },
    {
      "name": "Newsletter",
      "item": [
        {
          "name": "Subscribe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"subscriber@example.com\",\n  \"name\": \"John Doe\",\n  \"source\": \"footer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/newsletter/subscribe",
              "host": ["{{baseUrl}}"],
              "path": ["newsletter", "subscribe"]
            }
          }
        },
        {
          "name": "Unsubscribe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"subscriber@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/newsletter/unsubscribe",
              "host": ["{{baseUrl}}"],
              "path": ["newsletter", "unsubscribe"]
            }
          }
        },
        {
          "name": "Get All Subscribers (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/newsletter/admin/subscribers?isActive=true&page=1&limit=50",
              "host": ["{{baseUrl}}"],
              "path": ["newsletter", "admin", "subscribers"],
              "query": [
                {"key": "isActive", "value": "true"},
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "50"}
              ]
            }
          }
        },
        {
          "name": "Export Subscribers (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/newsletter/admin/export?isActive=true",
              "host": ["{{baseUrl}}"],
              "path": ["newsletter", "admin", "export"],
              "query": [{"key": "isActive", "value": "true"}]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ]
}
